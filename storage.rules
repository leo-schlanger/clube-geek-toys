rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(memberId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/members/$(memberId)) &&
        firestore.get(/databases/(default)/documents/members/$(memberId)).data.user_id == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============================================
    // CONTRACTS FOLDER
    // ============================================

    match /contracts/{memberId}/{fileName} {
      // Read: owner or admin can read their contracts
      allow read: if isOwner(memberId) || isAdmin();

      // Write: owner can upload their own contracts
      // Max 5MB, must be PDF
      allow write: if isOwner(memberId) &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType == 'application/pdf';

      // Delete: only admin
      allow delete: if isAdmin();
    }

    // ============================================
    // MEMBER PHOTOS FOLDER
    // ============================================

    match /member_photos/{memberId}/{fileName} {
      // Read: anyone authenticated can read photos (for displaying member cards)
      allow read: if isAuthenticated();

      // Write: owner can upload their own photo
      // Max 2MB, must be image
      allow write: if isOwner(memberId) &&
        request.resource.size < 2 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');

      // Delete: owner or admin
      allow delete: if isOwner(memberId) || isAdmin();
    }

    // ============================================
    // DEFAULT: DENY ALL
    // ============================================

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
