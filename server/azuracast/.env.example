# Configuração do AzuraCast
# Copie este arquivo para .env na VPS: cp .env.example .env
# e gere as senhas com: openssl rand -hex 24

# Fuso horário e idioma (padrão BR)
TIMEZONE=America/Sao_Paulo
LANG=pt_BR.UTF-8

# Banco MariaDB embutido (obrigatório no :latest)
MYSQL_DATABASE=azuracast
MYSQL_USER=azuracast
MYSQL_PASSWORD=gerar-com-openssl-rand-hex-24
MYSQL_ROOT_PASSWORD=gerar-com-openssl-rand-hex-24
