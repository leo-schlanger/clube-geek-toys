# PostgreSQL
POSTGRES_USER=clube_geek
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=clube_geek_toys

# JWT
JWT_SECRET=CHANGE_ME_64_char_random_string
JWT_REFRESH_SECRET=CHANGE_ME_different_64_char_random_string
HMAC_SECRET=CHANGE_ME_another_64_char_random_string

# Stripe
STRIPE_SECRET_KEY=sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_... (required in production)

# PIX
PIX_KEY=<chave PIX do recebedor>

# Google OAuth (optional)
GOOGLE_CLIENT_ID=<get from Google Cloud Console>

# Email (Resend)
RESEND_API_KEY=<get from Resend dashboard>
FROM_EMAIL=Clube Geek & Toys <contato@geeketoys.com.br>
ADMIN_EMAIL=admin@geeketoys.com.br

# URLs
FRONTEND_URL=https://club.geeketoys.com.br
API_URL=https://api.geeketoys.com.br
