rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if it's the user themselves
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Get user role from users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserRole() == 'admin';
    }

    // Check if user is seller or admin
    function isSellerOrAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserRole() in ['admin', 'seller'];
    }

    // Check if field is not being modified
    function fieldNotChanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // Check if ONLY specific fields are being modified
    function onlyFieldsChanged(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // ============================================
    // COLLECTION: USERS
    // ============================================

    match /users/{userId} {
      // Read: own user or admin
      allow read: if isOwner(userId) || isAdmin();

      // Create:
      // - User can only create their own doc with 'member' role (registration)
      // - Admin can create any user with any role (admin panel)
      allow create: if
        // Self-registration: must be own document with member role
        (isOwner(userId) &&
         request.resource.data.role == 'member' &&
         request.resource.data.keys().hasAll(['email', 'role', 'createdAt']))
        ||
        // Admin creation: admin can create any user document with any role
        (isAdmin() &&
         request.resource.data.role in ['admin', 'seller', 'member'] &&
         request.resource.data.keys().hasAll(['email', 'role', 'createdAt']));

      // Update: admin can change anything, user can update own profile but NOT role
      allow update: if isAdmin() ||
        (isOwner(userId) && fieldNotChanged('role'));

      // Delete: only admin
      allow delete: if isAdmin();
    }

    // ============================================
    // COLLECTION: MEMBERS
    // ============================================

    match /members/{memberId} {
      // Read: own member (by user_id), seller, or admin
      allow read: if isAuthenticated() &&
        (resource.data.user_id == request.auth.uid || isSellerOrAdmin());

      // Create: authenticated user (during registration) or admin
      // User can only create member for themselves
      allow create: if isAuthenticated() &&
        (request.resource.data.user_id == request.auth.uid || isAdmin());

      // Update rules:
      // - Admin can change anything
      // - Seller can ONLY update points and updated_at (for PDV)
      // - Member can update limited fields (phone, photo)
      allow update: if isAdmin() ||
        // Seller can only update points
        (isSellerOrAdmin() && onlyFieldsChanged(['points', 'updated_at'])) ||
        // Member can update own profile (except protected fields)
        (isAuthenticated() &&
         resource.data.user_id == request.auth.uid &&
         fieldNotChanged('cpf') &&
         fieldNotChanged('user_id') &&
         fieldNotChanged('plan') &&
         fieldNotChanged('status') &&
         fieldNotChanged('payment_type') &&
         fieldNotChanged('expiry_date') &&
         fieldNotChanged('points'));

      // Delete: only admin
      allow delete: if isAdmin();
    }

    // ============================================
    // COLLECTION: PAYMENTS
    // ============================================

    match /payments/{paymentId} {
      // Read: admin, seller, or payment owner (member who made the payment)
      allow read: if isSellerOrAdmin() ||
        (isAuthenticated() &&
         exists(/databases/$(database)/documents/members/$(resource.data.member_id)) &&
         get(/databases/$(database)/documents/members/$(resource.data.member_id)).data.user_id == request.auth.uid);

      // Create: authenticated user or system (Cloud Functions)
      allow create: if isAuthenticated();

      // Update: only admin or system (Cloud Functions with admin SDK bypass rules)
      allow update: if isAdmin();

      // Delete: never allowed (audit trail)
      allow delete: if false;
    }

    // ============================================
    // COLLECTION: CONFIG (system settings)
    // ============================================

    match /config/{configId} {
      // Read: any authenticated user
      allow read: if isAuthenticated();

      // Write: only admin
      allow write: if isAdmin();
    }

    // ============================================
    // COLLECTION: POINT_TRANSACTIONS
    // ============================================

    match /point_transactions/{transactionId} {
      // Read: own transactions (by member_id), seller, or admin
      allow read: if isAuthenticated() &&
        (exists(/databases/$(database)/documents/members/$(resource.data.member_id)) &&
         get(/databases/$(database)/documents/members/$(resource.data.member_id)).data.user_id == request.auth.uid ||
         isSellerOrAdmin());

      // Create: seller or admin (points are added at POS)
      allow create: if isSellerOrAdmin();

      // Update: never (immutable transactions)
      allow update: if false;

      // Delete: never (audit trail)
      allow delete: if false;
    }

    // ============================================
    // COLLECTION: AUDIT_LOGS
    // ============================================

    match /audit_logs/{logId} {
      // Read: only admin
      allow read: if isAdmin();

      // Create: seller or admin can create logs (for point operations, etc.)
      allow create: if isSellerOrAdmin();

      // Update: never (immutable logs)
      allow update: if false;

      // Delete: never (audit trail)
      allow delete: if false;
    }

    // ============================================
    // COLLECTION: EMAIL_LOGS
    // ============================================

    match /email_logs/{logId} {
      // Read: only admin
      allow read: if isAdmin();

      // Create: system only (via Cloud Functions/Workers - bypasses rules)
      // Frontend cannot create email logs directly
      allow create: if false;

      // Update: never (immutable logs)
      allow update: if false;

      // Delete: never (audit trail)
      allow delete: if false;
    }

    // ============================================
    // DEFAULT: DENY ALL
    // ============================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
