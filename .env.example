# ============================================
# API CONFIGURATION
# ============================================
# Em desenvolvimento: http://localhost:3001
# Em produção: https://api.geeketoys.com.br
VITE_API_URL=http://localhost:3001

# ============================================
# PAGBANK CONFIGURATION
# ============================================
# Public Key para encriptação de cartão no frontend
VITE_PAGBANK_PUBLIC_KEY=

# ============================================
# PIX CONFIGURATION
# ============================================
VITE_PIX_KEY=sua-chave-pix-aqui

# ============================================
# GOOGLE OAUTH (optional)
# ============================================
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=

# ============================================
# ENVIRONMENT
# ============================================
# development ou production
VITE_ENVIRONMENT=development
