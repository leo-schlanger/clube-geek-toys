# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Obtenha essas credenciais em:
# https://console.firebase.google.com/project/SEU-PROJETO/settings/general

VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto-id
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-sender-id
VITE_FIREBASE_APP_ID=seu-app-id

# ============================================
# MERCADO PAGO CONFIGURATION
# ============================================
# Obtenha essas credenciais em:
# https://www.mercadopago.com.br/developers/panel/app

# Public Key - usada no frontend para checkout
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL da API de pagamentos (Firebase Functions)
# Em desenvolvimento: http://localhost:5001/clube-geek-toys/southamerica-east1/api
# Em produção: https://southamerica-east1-clube-geek-toys.cloudfunctions.net/api
VITE_PAYMENT_API_URL=https://southamerica-east1-clube-geek-toys.cloudfunctions.net/api

# ============================================
# PIX CONFIGURATION (opcional - para simulação)
# ============================================
# Chave PIX da loja (email, telefone, CPF/CNPJ ou aleatória)
VITE_PIX_KEY=sua-chave-pix@email.com

# ============================================
# ENVIRONMENT
# ============================================
# development ou production
VITE_ENVIRONMENT=development
